{
  "name": "convertly-api",
  "version": "1.0.0",
  "type": "module",
  "description": "A SaaS-style API for file conversion using Node.js, Express, PostgreSQL, Prisma, Redis, and BullMQ",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "smoke": "powershell -ExecutionPolicy Bypass -File ./scripts/smoke.ps1 -BaseUrl http://localhost:3000 -FailOnConvertError",
    "validate": "powershell -ExecutionPolicy Bypass -File ./scripts/validate-local.ps1 -BaseUrl http://localhost:3000",
    "build": "echo 'No build step required'",
    "test": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --runInBand",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "worker": "node src/workers/conversion.worker.js"
  },
  "keywords": [
    "api",
    "file-conversion",
    "nodejs",
    "express",
    "prisma",
    "redis",
    "bullmq"
  ],
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "dependencies": {
    "@prisma/client": "^5.0.0",
    "bcrypt": "^5.1.0",
    "bullmq": "^4.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.0.0",
    "express": "^4.18.0",
    "express-rate-limit": "^6.7.0",
    "helmet": "^6.0.0",
    "jsonwebtoken": "^9.0.0",
    "multer": "^1.4.5-lts.1",
    "pdf-lib": "^1.17.1",
    "redis": "^4.6.0",
    "sharp": "^0.32.0",
    "swagger-jsdoc": "^6.2.0",
    "swagger-ui-express": "^4.6.0",
    "winston": "^3.8.0",
    "zod": "^3.21.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "jest": "^29.0.0",
    "nodemon": "^2.0.0",
    "prisma": "^5.0.0",
    "supertest": "^7.2.2"
  }
}
